        }
    },
    "test-redis-custom-config": {
        "image": "ghcr.io/kodansha/bedrock:php8.5-fpm",
        "features": {
            "bedrock-extra": {
                "redis": true,
                "redisVersion": "6.3.0RC1"
            }
        }
    },
