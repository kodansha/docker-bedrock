{
    "test-locale-is-not-set": {
        "image": "ghcr.io/kodansha/bedrock:php8.5-fpm",
        "features": {
            "bedrock-extra": {}
        }
    },
    "test-locale-is-set": {
        "image": "ghcr.io/kodansha/bedrock:php8.5-fpm",
        "features": {
            "bedrock-extra": {
                "locale": "ja_JP.UTF-8"
            }
        },
        "containerEnv": {
            "LANG": "ja_JP.UTF-8"
        }
    },
    "test-xdebug-is-not-set": {
        "image": "ghcr.io/kodansha/bedrock:php8.5-fpm",
        "features": {
            "bedrock-extra": {}
        }
    },
    "test-xdebug-is-set": {
        "image": "ghcr.io/kodansha/bedrock:php8.5-fpm",
        "features": {
            "bedrock-extra": {
                "xdebug": true
            }
        }
    },
    "test-xdebug-custom-config": {
        "image": "ghcr.io/kodansha/bedrock:php8.5-fpm",
        "features": {
            "bedrock-extra": {
                "xdebug": true,
                "xdebugVersion": "3.5.0alpha3",
                "xdebugClientHost": "host.docker.internal",
                "xdebugClientPort": "9999"
            }
        }
    },
    "test-redis-is-not-set": {
        "image": "ghcr.io/kodansha/bedrock:php8.5-fpm",
